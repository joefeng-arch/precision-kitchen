# ─────────────────────────────────────────────────────────────
# 老舅厨房 后端环境变量模板
# 复制此文件为 .env（开发）或 .env.production（生产），填入真实值
# 此文件安全入库，不含任何真实密钥
# ─────────────────────────────────────────────────────────────

# ── 数据库 ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ujk_dev
DB_USER=ujk_user
DB_PASSWORD=change-me

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT（用户端）────────────────────────────────────────────
# 生产值用：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-use-64-random-hex-chars-in-production
JWT_EXPIRES_IN=7d

# ── JWT（管理后台，独立 secret）──────────────────────────────
ADMIN_JWT_SECRET=change-me-use-another-64-random-hex-chars
ADMIN_JWT_EXPIRES_IN=12h

# ── 登录 ────────────────────────────────────────────────────
# 是否允许 mock 登录（开发 true，生产必须 false）
ALLOW_MOCK_LOGIN=true

# ── OAuth：Google 登录 ───────────────────────────────────────
# Google Cloud Console 为 iOS / Android / Web 分别注册的 OAuth Client ID
# （expo-auth-session 按平台用不同 Client ID，idToken 的 aud 会是三者之一，
#   配了几个就校验几个；一个都不配则 google 登录 fail closed → 401）
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# ── OAuth：Apple 登录 ────────────────────────────────────────
# Apple Developer 后台配置的 Services ID（web/AuthSession 流程用）
# 仅登录校验不需要 TEAM_ID / KEY_ID / PRIVATE_KEY（那些用于服务端刷新/撤销）
APPLE_CLIENT_ID=

# ── 订阅（RevenueCat）────────────────────────────────────────
# RC 后台 webhook 配置里填写的 Authorization 头原文；未配置时 webhook fail-closed（一律 401）
REVENUECAT_WEBHOOK_SECRET=

# ── 文件上传 ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── 服务器 ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── AI 智能导入（阿里百炼 DashScope） ───────────────────────
# 获取 API Key：https://bailian.console.aliyun.com/
AI_PROVIDER=alibaba
AI_API_KEY=your-dashscope-api-key-here
AI_MODEL=qwen-plus

# ── Seed 脚本（初始管理员密码）──────────────────────────────
# 仅 pnpm seed 时读取，生产环境运行 seed 后请立即在后台改密
ADMIN_SEED_PASSWORD=change-me-strong-password
