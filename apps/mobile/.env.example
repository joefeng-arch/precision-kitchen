# 复制为 .env（gitignore，本地开发用）
#
# EXPO_PUBLIC_API_BASE_URL 三种取值场景（后端固定跑在 3001 端口，全局前缀 /api）：
#   iOS Simulator            http://localhost:3001/api
#   Android Emulator (AVD)   http://10.0.2.2:3001/api        （localhost 指向模拟器自身）
#   真机 / Expo Go（同 Wi-Fi） http://192.168.x.x:3001/api      （换成宿主机的 LAN IP）
#
# 后端 CORS 已全开，不需要为任何一种取值改后端配置。
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api

# ── OAuth 登录（Client ID 是公开标识，非密钥，打进客户端包是正常的）──
# Google Cloud Console 按平台注册的 OAuth Client ID；不配则对应按钮禁用
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Apple Developer 后台的 Services ID（web/AuthSession 流程）；不配则按钮禁用
EXPO_PUBLIC_APPLE_CLIENT_ID=
